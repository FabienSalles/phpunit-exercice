{
    "name": "conveycode/phpunit-exercice",
    "description": "PHPUnit training exercises — Day 1",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-bcmath": "*",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1",
        "phpspec/prophecy": "^1.19",
        "phpspec/prophecy-phpunit": "^2.2",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "Conveycode\\PhpunitExercice\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Conveycode\\PhpunitExercice\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
